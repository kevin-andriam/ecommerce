<!DOCTYPE html>
<html lang="fr" id="html-root">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}UTRAKT{% endblock %}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: '#6366f1',
                        secondary: '#f1f5f9',
                    }
                }
            }
        }
    </script>
    <script>
        if (localStorage.getItem('theme') === 'dark') {
            document.documentElement.classList.add('dark');
        }
    </script>
</head>
<body class="bg-gray-50 dark:bg-gray-950 text-gray-800 dark:text-gray-200 min-h-screen transition-colors duration-300">

    <!-- Navbar -->
    <nav class="bg-white dark:bg-gray-900 shadow-sm border-b border-gray-100 dark:border-gray-800 sticky top-0 z-50">
        <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
            <a href="/" class="text-2xl font-bold text-indigo-600 dark:text-indigo-400 tracking-tight">UTRAKT</a>
            <div class="flex items-center gap-6 text-sm font-medium text-gray-600 dark:text-gray-300">

                {% if not is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('product_index') }}" class="hover:text-indigo-600 dark:hover:text-indigo-400 transition">Produits</a>
                    <a href="{{ path('category_index') }}" class="hover:text-indigo-600 dark:hover:text-indigo-400 transition">Catégories</a>
                    <a href="{{ path('cart_index') }}" class="hover:text-indigo-600 dark:hover:text-indigo-400 transition">🛒 Panier</a>
                {% endif %}

                {% if app.user %}
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('admin') }}"
                           class="bg-indigo-600 text-white px-4 py-2 rounded-full hover:bg-indigo-700 transition">
                            ⚙️ Administration
                        </a>
                    {% else %}
                        <span class="text-gray-400 dark:text-gray-500">👤 {{ app.user.email }}</span>
                    {% endif %}
                    <a href="{{ path('app_logout') }}"
                       class="bg-red-50 dark:bg-red-900 text-red-500 dark:text-red-400 px-3 py-1 rounded-full hover:bg-red-100 dark:hover:bg-red-800 transition">
                        Déconnexion
                    </a>
                {% else %}
                    <a href="{{ path('app_login') }}" class="hover:text-indigo-600 dark:hover:text-indigo-400 transition">Connexion</a>
                    <a href="{{ path('app_register') }}" class="bg-indigo-600 text-white px-4 py-2 rounded-full hover:bg-indigo-700 transition">S'inscrire</a>
                {% endif %}

                <!-- Bouton Dark/Light Mode -->
                <button id="theme-toggle"
                        class="w-9 h-9 flex items-center justify-center rounded-full border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 hover:bg-gray-100 dark:hover:bg-gray-700 transition">
                    <span id="theme-icon">🌙</span>
                </button>

            </div>
        </div>
    </nav>

    <!-- Contenu -->
    <main class="max-w-6xl mx-auto px-4 py-10">
        {% for message in app.flashes('success') %}
            <div class="mb-4 bg-green-50 dark:bg-green-900 border border-green-200 dark:border-green-700 text-green-700 dark:text-green-400 px-4 py-3 rounded-lg">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('warning') %}
            <div class="mb-4 bg-yellow-50 dark:bg-yellow-900 border border-yellow-200 dark:border-yellow-700 text-yellow-700 dark:text-yellow-400 px-4 py-3 rounded-lg">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('info') %}
            <div class="mb-4 bg-blue-50 dark:bg-blue-900 border border-blue-200 dark:border-blue-700 text-blue-700 dark:text-blue-400 px-4 py-3 rounded-lg">{{ message }}</div>
        {% endfor %}

        {% block body %}{% endblock %}
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-100 dark:border-gray-800 mt-20 py-8 text-center text-sm text-gray-400 dark:bg-gray-900">
        © 2026 Erica & Kevin's shop — Tous droits réservés
    </footer>

    <!-- Script Dark/Light Mode -->
    <script>
        const btn = document.getElementById('theme-toggle');
        const icon = document.getElementById('theme-icon');
        const html = document.documentElement;

        if (html.classList.contains('dark')) {
            icon.textContent = '☀️';
        } else {
            icon.textContent = '🌙';
        }

        btn.addEventListener('click', () => {
            html.classList.toggle('dark');
            if (html.classList.contains('dark')) {
                localStorage.setItem('theme', 'dark');
                icon.textContent = '☀️';
            } else {
                localStorage.setItem('theme', 'light');
                icon.textContent = '🌙';
            }
        });
    </script>

</body>
</html>