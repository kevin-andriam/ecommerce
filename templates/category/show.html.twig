{% extends 'base.html.twig' %}

{% block title %}{{ category.nom }}{% endblock %}

{% block body %}

<nav class="text-sm text-gray-400 dark:text-gray-500 mb-8">
    <a href="{{ path('category_index') }}" class="hover:text-indigo-600 dark:hover:text-indigo-400">Catégories</a>
    <span class="mx-2">›</span>
    <span class="text-gray-600 dark:text-gray-300">{{ category.nom }}</span>
</nav>

<div class="text-center mb-12">
    <h1 class="text-4xl font-bold text-gray-900 dark:text-gray-100 mb-3">{{ category.nom }}</h1>
    <p class="text-gray-500 dark:text-gray-400">{{ category.products|length }} produit(s) disponible(s)</p>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
    {% for product in category.products %}
    <div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-100 dark:border-gray-700 hover:shadow-md dark:hover:border-indigo-500 transition overflow-hidden">
        <div class="bg-gradient-to-br from-indigo-50 to-purple-50 dark:from-gray-700 dark:to-gray-600 h-48 flex items-center justify-center">
            <span class="text-6xl">📦</span>
        </div>
        <div class="p-5">
            <h2 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-2">{{ product.name }}</h2>
            <p class="text-gray-500 dark:text-gray-400 text-sm mb-4">{{ product.description|slice(0, 80) }}...</p>
            <div class="flex items-center justify-between mb-4">
                <span class="text-2xl font-bold text-indigo-600 dark:text-indigo-400">{{ product.price }} €</span>
                <span class="text-xs text-gray-400 dark:text-gray-500">Stock : {{ product.stock }}</span>
            </div>
            <a href="{{ path('product_show', {id: product.id}) }}"
               class="block text-center bg-indigo-600 text-white py-2 rounded-xl text-sm font-medium hover:bg-indigo-700 transition">
                Voir le produit
            </a>
        </div>
    </div>
    {% else %}
        <p class="text-gray-400 col-span-3 text-center">Aucun produit dans cette catégorie.</p>
    {% endfor %}
</div>

<div class="mt-8">
    <a href="{{ path('category_index') }}" class="text-indigo-600 dark:text-indigo-400 hover:underline">← Retour aux catégories</a>
</div>
{% endblock %}