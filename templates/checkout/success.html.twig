{% extends 'base.html.twig' %}

{% block title %}Commande confirmée{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center -mt-10">
    <div class="w-full max-w-md text-center">

        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-12">

            <!-- Icône succès -->
            <div class="w-20 h-20 bg-green-50 rounded-full flex items-center justify-center mx-auto mb-6">
                <span class="text-4xl">🎉</span>
            </div>

            <h1 class="text-3xl font-bold text-gray-900 mb-2">Merci !</h1>
            <p class="text-gray-500 mb-8">Votre commande a été passée avec succès</p>

            <div class="bg-gray-50 rounded-xl p-5 mb-8 space-y-3 text-left">
                <div class="flex justify-between text-sm">
                    <span class="text-gray-500">Numéro de commande</span>
                    <span class="font-bold text-gray-900">#{{ order.id }}</span>
                </div>
                <div class="flex justify-between text-sm">
                    <span class="text-gray-500">Total</span>
                    <span class="font-bold text-indigo-600">{{ order.total|number_format(2) }} €</span>
                </div>
                <div class="flex justify-between text-sm">
                    <span class="text-gray-500">Statut</span>
                    <span class="bg-yellow-100 text-yellow-700 text-xs px-3 py-1 rounded-full font-medium">
                        {{ order.status }}
                    </span>
                </div>
            </div>

            <a href="{{ path('product_index') }}"
               class="block bg-indigo-600 text-white py-3 rounded-xl font-semibold hover:bg-indigo-700 transition">
                Continuer mes achats
            </a>

            <a href="{{ path('home') }}"
               class="block text-gray-400 text-sm mt-3 hover:text-indigo-600 transition">
                ← Retour à l'accueil
            </a>
        </div>

    </div>
</div>
{% endblock %}