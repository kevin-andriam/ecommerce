{% extends 'base.html.twig' %}

{% block title %}Confirmer la commande{% endblock %}

{% block body %}

<div class="text-center mb-10">
    <h1 class="text-4xl font-bold text-gray-900 mb-2">✅ Confirmer la commande</h1>
    <p class="text-gray-500">Vérifiez votre commande avant de confirmer</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

    <!-- Colonne gauche -->
    <div class="lg:col-span-2 space-y-6">

        <!-- Récapitulatif produits -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100">
                <h2 class="font-bold text-gray-900 text-lg">🛒 Récapitulatif</h2>
            </div>
            <div class="divide-y divide-gray-50">
                {% for item in items %}
                <div class="flex items-center gap-4 px-6 py-4">
                    <div class="bg-gradient-to-br from-indigo-50 to-purple-50 rounded-xl w-14 h-14 flex items-center justify-center flex-shrink-0">
                        <span class="text-2xl">📦</span>
                    </div>
                    <div class="flex-1">
                        <h3 class="font-semibold text-gray-900">{{ item.product.name }}</h3>
                        <p class="text-sm text-gray-400">Quantité : {{ item.quantity }}</p>
                    </div>
                    <div class="text-right">
                        <p class="font-bold text-gray-900">{{ (item.product.price * item.quantity)|number_format(2) }} €</p>
                        <p class="text-sm text-gray-400">{{ item.product.price }} € / unité</p>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>

        <!-- Informations de livraison -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100">
                <h2 class="font-bold text-gray-900 text-lg">📦 Informations de livraison</h2>
            </div>
            <div class="px-6 py-5 space-y-3">
                <div class="flex justify-between text-sm">
                    <span class="text-gray-500">Nom</span>
                    <span class="font-medium text-gray-900">
                        {{ app.user.firstName }} {{ app.user.lastName }}
                    </span>
                </div>
                <div class="flex justify-between text-sm">
                    <span class="text-gray-500">Email</span>
                    <span class="font-medium text-gray-900">{{ app.user.email }}</span>
                </div>
                <div class="flex justify-between text-sm">
                    <span class="text-gray-500">Adresse</span>
                    <span class="font-medium text-gray-900">
                        {{ app.user.address ?? 'Non renseignée' }}
                    </span>
                </div>
            </div>
        </div>

    </div>

    <!-- Colonne droite — Résumé -->
    <div class="lg:col-span-1">
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 sticky top-24">
            <h2 class="text-xl font-bold text-gray-900 mb-6">Résumé</h2>

            <div class="space-y-3 mb-6">
                {% for item in items %}
                <div class="flex justify-between text-sm text-gray-500">
                    <span>{{ item.product.name }} × {{ item.quantity }}</span>
                    <span>{{ (item.product.price * item.quantity)|number_format(2) }} €</span>
                </div>
                {% endfor %}
            </div>

            <div class="border-t border-gray-100 pt-4 mb-6">
                <div class="flex justify-between items-center">
                    <span class="font-bold text-gray-900">Total</span>
                    <span class="text-2xl font-bold text-indigo-600">{{ total|number_format(2) }} €</span>
                </div>
            </div>

            <form method="post" action="{{ path('checkout_confirm') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('checkout') }}">
                <button type="submit"
                        class="w-full bg-indigo-600 text-white py-3 rounded-xl font-semibold hover:bg-indigo-700 transition">
                    ✅ Confirmer la commande
                </button>
            </form>

            <a href="{{ path('cart_index') }}"
               class="block text-center text-gray-400 text-sm mt-3 hover:text-indigo-600 transition">
                ← Retour au panier
            </a>
        </div>
    </div>

</div>

{% endblock %}