{% extends '@EasyAdmin/page/content.html.twig' %}

{% block main %}
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <a href="{{ ea_url().setController('App\\Controller\\Admin\\ProductCrudController').setAction('index') }}" class="text-decoration-none">
            <div class="card text-white bg-primary h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title mb-0">Produits</h6>
                        <small>Gérer le catalogue</small>
                    </div>
                    <span style="font-size: 2rem;">📦</span>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="{{ ea_url().setController('App\\Controller\\Admin\\CategoryCrudController').setAction('index') }}" class="text-decoration-none">
            <div class="card text-white bg-success h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title mb-0">Catégories</h6>
                        <small>Organiser les produits</small>
                    </div>
                    <span style="font-size: 2rem;">🗂️</span>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="{{ ea_url().setController('App\\Controller\\Admin\\OrderCrudController').setAction('index') }}" class="text-decoration-none">
            <div class="card text-white bg-warning h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title mb-0">Commandes</h6>
                        <small>Suivre les ventes</small>
                    </div>
                    <span style="font-size: 2rem;">🛒</span>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="{{ ea_url().setController('App\\Controller\\Admin\\UserCrudController').setAction('index') }}" class="text-decoration-none">
            <div class="card text-white bg-danger h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title mb-0">Utilisateurs</h6>
                        <small>Gérer les comptes</small>
                    </div>
                    <span style="font-size: 2rem;">👤</span>
                </div>
            </div>
        </a>
    </div>
</div>
{% endblock %}