{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center -mt-10">
    <div class="w-full max-w-md">
        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100">Créer un compte 🎉</h1>
            <p class="text-gray-500 dark:text-gray-400 mt-2">Rejoignez MonShop dès aujourd'hui</p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-100 dark:border-gray-700 p-8">

            {{ form_errors(registrationForm) }}

            {{ form_start(registrationForm, {'attr': {'class': 'space-y-5'}}) }}

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        {{ form_label(registrationForm.firstName, 'Prénom', {
                            'label_attr': {'class': 'block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1'}
                        }) }}
                        {{ form_widget(registrationForm.firstName, {
                            'attr': {
                                'class': 'w-full bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-xl px-4 py-3 text-sm text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500 transition',
                                'placeholder': 'Prénom'
                            }
                        }) }}
                        {{ form_errors(registrationForm.firstName) }}
                    </div>
                    <div>
                        {{ form_label(registrationForm.lastName, 'Nom', {
                            'label_attr': {'class': 'block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1'}
                        }) }}
                        {{ form_widget(registrationForm.lastName, {
                            'attr': {
                                'class': 'w-full bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-xl px-4 py-3 text-sm text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500 transition',
                                'placeholder': 'Nom'
                            }
                        }) }}
                        {{ form_errors(registrationForm.lastName) }}
                    </div>
                </div>

                <div>
                    {{ form_label(registrationForm.email, 'Email', {
                        'label_attr': {'class': 'block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1'}
                    }) }}
                    {{ form_widget(registrationForm.email, {
                        'attr': {
                            'class': 'w-full bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-xl px-4 py-3 text-sm text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500 transition',
                            'placeholder': 'votre@email.com'
                        }
                    }) }}
                    {{ form_errors(registrationForm.email) }}
                </div>

                <div>
                    {{ form_label(registrationForm.plainPassword, 'Mot de passe', {
                        'label_attr': {'class': 'block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1'}
                    }) }}
                    {{ form_widget(registrationForm.plainPassword, {
                        'attr': {
                            'class': 'w-full bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-xl px-4 py-3 text-sm text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500 transition',
                            'placeholder': '••••••••'
                        }
                    }) }}
                    {{ form_errors(registrationForm.plainPassword) }}
                </div>

                <div class="flex items-center gap-3">
                    {{ form_widget(registrationForm.agreeTerms, {
                        'attr': {'class': 'w-4 h-4 text-indigo-600 rounded'}
                    }) }}
                    {{ form_label(registrationForm.agreeTerms, "J'accepte les conditions d'utilisation", {
                        'label_attr': {'class': 'text-sm text-gray-600 dark:text-gray-400'}
                    }) }}
                    {{ form_errors(registrationForm.agreeTerms) }}
                </div>

                <button type="submit"
                        class="w-full bg-indigo-600 text-white py-3 rounded-xl font-semibold hover:bg-indigo-700 transition">
                    Créer mon compte
                </button>

            {{ form_end(registrationForm) }}

            <p class="text-center text-sm text-gray-500 dark:text-gray-400 mt-6">
                Déjà un compte ?
                <a href="{{ path('app_login') }}" class="text-indigo-600 dark:text-indigo-400 font-medium hover:underline">
                    Se connecter
                </a>
            </p>
        </div>
    </div>
</div>
{% endblock %}