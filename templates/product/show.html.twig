{% extends 'base.html.twig' %}

{% block title %}{{ product.name }}{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto">

    <nav class="text-sm text-gray-400 dark:text-gray-500 mb-8">
        <a href="{{ path('product_index') }}" class="hover:text-indigo-600 dark:hover:text-indigo-400">Produits</a>
        <span class="mx-2">›</span>
        <span class="text-gray-600 dark:text-gray-300">{{ product.name }}</span>
    </nav>

    <div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-100 dark:border-gray-700 overflow-hidden">
        <div class="grid grid-cols-1 md:grid-cols-2">
            <div class="bg-gradient-to-br from-indigo-50 to-purple-50 dark:from-gray-700 dark:to-gray-600 h-80 flex items-center justify-center">
                <span class="text-9xl">📦</span>
            </div>
            <div class="p-8 flex flex-col justify-between">
                <div>
                    <span class="text-xs font-semibold text-indigo-500 dark:text-indigo-400 uppercase tracking-wide">
                        {{ product.category.nom }}
                    </span>
                    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mt-2 mb-4">{{ product.name }}</h1>
                    <p class="text-gray-500 dark:text-gray-400 leading-relaxed mb-6">{{ product.description }}</p>
                    <div class="flex items-center gap-4 mb-6">
                        <span class="text-xl font-bold text-white bg-indigo-600 dark:bg-indigo-500 px-3 py-1 rounded-full">{{ product.price }} €</span>
                        {% if product.stock > 0 %}
                            <span class="bg-green-50 dark:bg-green-900 text-green-600 dark:text-green-400 text-sm px-3 py-1 rounded-full">
                                ✅ En stock ({{ product.stock }})
                            </span>
                        {% else %}
                            <span class="bg-red-50 dark:bg-red-900 text-red-500 dark:text-red-400 text-sm px-3 py-1 rounded-full">
                                ❌ Rupture de stock
                            </span>
                        {% endif %}
                    </div>
                </div>
                <div class="flex gap-3">
                    <a href="{{ path('cart_add', {id: product.id}) }}"
                       class="flex-1 text-center bg-indigo-600 text-white py-3 rounded-xl font-semibold hover:bg-indigo-700 transition">
                        🛒 Ajouter au panier
                    </a>
                    <a href="{{ path('product_index') }}"
                       class="px-4 py-3 border border-gray-200 dark:border-gray-600 rounded-xl text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 transition">
                        ←
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}