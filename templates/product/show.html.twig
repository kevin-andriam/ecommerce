{% extends 'base.html.twig' %}

{% block title %}{{ product.name }}{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto">

    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-400 mb-8">
        <a href="{{ path('product_index') }}" class="hover:text-indigo-600">Produits</a>
        <span class="mx-2">›</span>
        <span class="text-gray-600">{{ product.name }}</span>
    </nav>

    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="grid grid-cols-1 md:grid-cols-2">

            <!-- Image -->
            <div class="bg-gradient-to-br from-indigo-50 to-purple-50 h-80 flex items-center justify-center">
                <span class="text-9xl">📦</span>
            </div>

            <!-- Infos -->
            <div class="p-8 flex flex-col justify-between">
                <div>
                    <span class="text-xs font-semibold text-indigo-500 uppercase tracking-wide">
                        {{ product.category.nom }}
                    </span>
                    <h1 class="text-3xl font-bold text-gray-900 mt-2 mb-4">{{ product.name }}</h1>
                    <p class="text-gray-500 leading-relaxed mb-6">{{ product.description }}</p>

                    <div class="flex items-center gap-4 mb-6">
                        <span class="text-4xl font-bold text-indigo-600">{{ product.price }} €</span>
                        {% if product.stock > 0 %}
                            <span class="bg-green-50 text-green-600 text-sm px-3 py-1 rounded-full">
                                ✅ En stock ({{ product.stock }})
                            </span>
                        {% else %}
                            <span class="bg-red-50 text-red-500 text-sm px-3 py-1 rounded-full">
                                ❌ Rupture de stock
                            </span>
                        {% endif %}
                    </div>
                </div>

                <div class="flex gap-3">
                    <a href="{{ path('cart_add', {id: product.id}) }}"
                       class="flex-1 text-center bg-indigo-600 text-white py-3 rounded-xl font-semibold hover:bg-indigo-700 transition">
                        🛒 Ajouter au panier
                    </a>
                    <a href="{{ path('product_index') }}"
                       class="px-4 py-3 border border-gray-200 rounded-xl text-gray-500 hover:bg-gray-50 transition">
                        ←
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}