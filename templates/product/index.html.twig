{% extends 'base.html.twig' %}

{% block title %}Nos Produits{% endblock %}

{% block body %}

<div class="text-center mb-10">
    <h1 class="text-4xl font-bold text-gray-900 dark:text-gray-100 mb-3">Nos Produits</h1>
    <p class="text-gray-500 dark:text-gray-400 text-lg">Découvrez notre sélection de produits de qualité</p>
</div>

<!-- Filtres -->
<div class="flex flex-wrap gap-3 mb-8 items-center">

    <!-- Recherche -->
    <div class="relative flex-1 min-w-48">
        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm">🔍</span>
        <input type="text" id="search"
               placeholder="Rechercher un produit..."
               class="w-full bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-full pl-9 pr-4 py-2 text-sm text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500 transition">
    </div>

    <!-- Catégorie -->
    <select id="category"
            class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-full px-4 py-2 text-sm text-gray-700 dark:text-gray-300 focus:outline-none focus:ring-2 focus:ring-indigo-500 transition">
        <option value="">Toutes les catégories</option>
        {% for category in categories %}
            <option value="{{ category.nom }}">{{ category.nom }}</option>
        {% endfor %}
    </select>

    <!-- Tri -->
    <select id="sort"
            class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-full px-4 py-2 text-sm text-gray-700 dark:text-gray-300 focus:outline-none focus:ring-2 focus:ring-indigo-500 transition">
        <option value="">Plus récents</option>
        <option value="price_asc">Prix ↑</option>
        <option value="price_desc">Prix ↓</option>
        <option value="name_asc">A-Z</option>
    </select>

    <!-- Réinitialiser -->
    <button id="reset"
            class="text-sm text-gray-400 dark:text-gray-500 hover:text-indigo-600 dark:hover:text-indigo-400 transition px-2">
        ✕ Réinitialiser
    </button>

</div>

<!-- Compteur résultats -->
<div class="flex items-center justify-between mb-5">
    <p class="text-sm text-gray-500 dark:text-gray-400">
        <span id="count" class="font-semibold text-gray-900 dark:text-gray-100">{{ products|length }}</span> produit(s) trouvé(s)
    </p>
</div>

<!-- Grille produits -->
<div id="product-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
    {% for product in products %}
    <div class="product-card bg-white dark:bg-gray-800 rounded-2xl border-2 border-gray-400 dark:border-gray-600 hover:border-indigo-500 dark:hover:border-indigo-400 hover:shadow-lg transition overflow-hidden"
         data-name="{{ product.name|lower }}"
         data-description="{{ product.description|lower }}"
         data-category="{{ product.category.nom }}"
         data-price="{{ product.price }}">
        <div class="bg-gradient-to-br from-indigo-50 to-purple-50 dark:from-gray-700 dark:to-gray-600 h-40 flex items-center justify-center">
            <span class="text-5xl">📦</span>
        </div>
        <div class="p-4">
            <span class="text-xs font-semibold text-indigo-500 dark:text-indigo-400 uppercase tracking-wide">
                {{ product.category.nom }}
            </span>
            <h2 class="text-base font-bold text-gray-900 dark:text-gray-100 mt-1 mb-1 line-clamp-1">
                {{ product.name }}
            </h2>
            <p class="text-gray-500 dark:text-gray-400 text-xs mb-3 line-clamp-2">
                {{ product.description|slice(0, 60) }}...
            </p>
            <div class="flex items-center justify-between mb-3">
                <span class="text-xl font-bold text-indigo-600 dark:text-indigo-400">{{ product.price }} €</span>
                <span class="text-xs text-gray-400 dark:text-gray-500">Stock : {{ product.stock }}</span>
            </div>
            <div class="flex gap-2">
                <a href="{{ path('product_show', {id: product.id}) }}"
                   class="flex-1 text-center border border-indigo-600 dark:border-indigo-400 text-indigo-600 dark:text-indigo-400 py-1.5 rounded-xl text-xs font-medium hover:bg-indigo-50 dark:hover:bg-indigo-900 transition">
                    Voir
                </a>
                <a href="{{ path('cart_add', {id: product.id}) }}"
                   class="flex-1 text-center bg-indigo-600 text-white py-1.5 rounded-xl text-xs font-medium hover:bg-indigo-700 transition">
                    🛒 Ajouter
                </a>
            </div>
        </div>
    </div>
    {% endfor %}
</div>

<!-- Message aucun résultat -->
<div id="no-results" class="hidden text-center py-16">
    <div class="text-6xl mb-4">🔍</div>
    <p class="text-gray-400 dark:text-gray-500 text-lg">Aucun produit trouvé</p>
    <button onclick="document.getElementById('reset').click()"
            class="text-indigo-600 dark:text-indigo-400 text-sm hover:underline mt-2 block mx-auto">
        Réinitialiser les filtres
    </button>
</div>

<script>
    const searchInput = document.getElementById('search');
    const categorySelect = document.getElementById('category');
    const sortSelect = document.getElementById('sort');
    const resetBtn = document.getElementById('reset');
    const cards = document.querySelectorAll('.product-card');
    const countEl = document.getElementById('count');
    const noResults = document.getElementById('no-results');
    const grid = document.getElementById('product-grid');

    function filterProducts() {
        const search = searchInput.value.toLowerCase();
        const category = categorySelect.value;
        const sort = sortSelect.value;

        let visibleCards = [];

        cards.forEach(card => {
            const name = card.dataset.name;
            const description = card.dataset.description;
            const cardCategory = card.dataset.category;

            const matchSearch = name.includes(search) || description.includes(search);
            const matchCategory = category === '' || cardCategory === category;

            if (matchSearch && matchCategory) {
                card.classList.remove('hidden');
                visibleCards.push(card);
            } else {
                card.classList.add('hidden');
            }
        });

        // Tri
        if (sort && visibleCards.length > 0) {
            visibleCards.sort((a, b) => {
                if (sort === 'price_asc') return parseFloat(a.dataset.price) - parseFloat(b.dataset.price);
                if (sort === 'price_desc') return parseFloat(b.dataset.price) - parseFloat(a.dataset.price);
                if (sort === 'name_asc') return a.dataset.name.localeCompare(b.dataset.name);
                return 0;
            });
            visibleCards.forEach(card => grid.appendChild(card));
        }

        // Compteur
        countEl.textContent = visibleCards.length;

        // Message aucun résultat
        if (visibleCards.length === 0) {
            noResults.classList.remove('hidden');
        } else {
            noResults.classList.add('hidden');
        }
    }

    // Écouter les changements en temps réel
    searchInput.addEventListener('input', filterProducts);
    categorySelect.addEventListener('change', filterProducts);
    sortSelect.addEventListener('change', filterProducts);

    // Réinitialiser
    resetBtn.addEventListener('click', () => {
        searchInput.value = '';
        categorySelect.value = '';
        sortSelect.value = '';
        filterProducts();
    });
</script>

{% endblock %}