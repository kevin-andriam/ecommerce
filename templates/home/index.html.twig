{% extends 'base.html.twig' %}

{% block title %}MonShop — Accueil{% endblock %}

{% block body %}

<!-- Hero -->
<div class="bg-gradient-to-br from-indigo-600 to-purple-600 rounded-3xl p-16 text-center text-white mb-16">
    <h1 class="text-5xl font-bold mb-4">Bienvenue sur MonShop 🛒</h1>
    <p class="text-indigo-100 text-xl mb-8">Découvrez nos produits de qualité à prix accessibles</p>
    <div class="flex gap-4 justify-center">
        <a href="{{ path('product_index') }}"
           class="bg-white text-indigo-600 px-8 py-3 rounded-xl font-semibold hover:bg-indigo-50 transition">
            Voir les produits
        </a>
        <a href="{{ path('category_index') }}"
           class="border border-white text-white px-8 py-3 rounded-xl font-semibold hover:bg-white/10 transition">
            Nos catégories
        </a>
    </div>
</div>

<!-- Catégories -->
<div class="mb-16">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">Nos catégories</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {% for category in categories %}
        <a href="{{ path('category_show', {id: category.id}) }}"
           class="bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md hover:border-indigo-200 transition p-6 text-center group">
            <div class="text-4xl mb-3">🗂️</div>
            <h3 class="font-semibold text-gray-900 group-hover:text-indigo-600 transition">
                {{ category.nom }}
            </h3>
            <p class="text-xs text-gray-400 mt-1">{{ category.products|length }} produit(s)</p>
        </a>
        {% endfor %}
    </div>
</div>

<!-- Derniers produits -->
<div class="mb-16">
    <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-gray-900">Nouveautés</h2>
        <a href="{{ path('product_index') }}" class="text-indigo-600 text-sm hover:underline">
            Voir tout →
        </a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {% for product in products %}
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition overflow-hidden group">
            <div class="bg-gradient-to-br from-indigo-50 to-purple-50 h-48 flex items-center justify-center">
                <span class="text-6xl">📦</span>
            </div>
            <div class="p-5">
                <span class="text-xs font-semibold text-indigo-500 uppercase tracking-wide">
                    {{ product.category.nom }}
                </span>
                <h3 class="text-lg font-bold text-gray-900 mt-1 mb-2">{{ product.name }}</h3>
                <p class="text-gray-500 text-sm mb-4">{{ product.description|slice(0, 80) }}...</p>
                <div class="flex items-center justify-between">
                    <span class="text-2xl font-bold text-indigo-600">{{ product.price }} €</span>
                    <div class="flex gap-2">
                        <a href="{{ path('product_show', {id: product.id}) }}"
                           class="border border-indigo-600 text-indigo-600 px-3 py-2 rounded-xl text-sm hover:bg-indigo-50 transition">
                            Voir
                        </a>
                        <a href="{{ path('cart_add', {id: product.id}) }}"
                           class="bg-indigo-600 text-white px-3 py-2 rounded-xl text-sm hover:bg-indigo-700 transition">
                            🛒
                        </a>
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
</div>

<!-- Banner -->
<div class="bg-gradient-to-br from-indigo-600 to-purple-600 rounded-3xl p-12 text-center text-white">
    <h2 class="text-3xl font-bold mb-3">Prêt à commander ? 🚀</h2>
    <p class="text-indigo-100 mb-6">Créez un compte et profitez de nos offres exclusives</p>
    {% if not app.user %}
        <a href="{{ path('app_register') }}"
           class="bg-white text-indigo-600 px-8 py-3 rounded-xl font-semibold hover:bg-indigo-50 transition">
            Créer un compte gratuitement
        </a>
    {% else %}
        <a href="{{ path('product_index') }}"
           class="bg-white text-indigo-600 px-8 py-3 rounded-xl font-semibold hover:bg-indigo-50 transition">
            Continuer mes achats
        </a>
    {% endif %}
</div>

{% endblock %}